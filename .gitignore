# python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# venv
.venv/
venv/
env/

# env / secrets — NEVER commit
.env
*.env
secrets/

# real gate data (bank/password/contract) — keep only the *.example.json
examples/gate_data.json
gate_data.json

# local data (sqlite db, screenshots, browser state) — ignore contents EXCEPT the learned
# LLM page-maps, which we DO commit so a fresh clone/deploy doesn't re-call the LLM.
data/*
!data/.gitkeep
!data/page_maps_*.json
artifacts/
screenshots/
storage_state.json

# os / editor
.DS_Store
.idea/
.vscode/
*.log
.gstack/

# --- per-OTA login cookies (sensitive — never commit) ---
storage_state_*.json
# (page_maps_*.json are intentionally committed via the data/ rule above — they hold no secrets)

# --- local scratch / test output ---
*.png
test-reports/
.pytest_cache/
service.log
qt*.txt
suite*.txt
finalsuite*.txt
fails.txt
r.txt
result.txt
test_out.txt
wtest.txt

# runtime-only file the Restart button touches to trigger a uvicorn --reload restart
accounts_pilot/_restart_trigger.py
