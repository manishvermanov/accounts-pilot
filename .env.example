# Copy to .env and fill in. .env is gitignored.

# --- runtime ---
HEADLESS=false            # set true for unattended runs
SLOW_MO_MS=0              # add delay between actions for debugging (e.g. 250)
USE_STEALTH=auto          # auto | always | never  (auto = adapter decides per step)

# --- humanisation (behavioural anti-bot evasion) ---
HUMANIZE=true             # curved mouse paths + char-by-char typing. Keep true vs OTAs.
KEY_DELAY_MIN_S=0.04      # per-keystroke delay floor
KEY_DELAY_MAX_S=0.17      # per-keystroke delay ceiling
THINK_MIN_S=0.3           # inter-action "think" pause floor
THINK_MAX_S=1.1           # inter-action "think" pause ceiling

# --- proxy (optional, for stealth / geo) ---
# socks5://user:pass@host:port  or  http://...
CLOAK_PROXY=

# --- OTA partner credentials (the service logs in with these) ---
# NEVER commit a real .env. The service fills these at the account/login step.
BOOKING_PARTNER_EMAIL=
BOOKING_PARTNER_PASSWORD=

# --- AgentQL (local fill: cloud resolves elements, actions run local) ---
AGENTQL_API_KEY=          # from dev.agentql.com

# --- captcha solver ---
CAPTCHA_PROVIDER=twocaptcha   # twocaptcha | capsolver | azcaptcha | none
CAPTCHA_API_KEY=

# --- otp ---
# OTP (email or phone) is entered by the owner when the service prompts. No config.

# --- storage ---
DB_PATH=data/accounts_pilot.db
ARTIFACTS_DIR=data/artifacts
